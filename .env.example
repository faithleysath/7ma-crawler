# 默认使用 compose 内置 PostgreSQL。
COMPOSE_PROFILES=local-db
DATABASE_URL=postgresql://sevenma:sevenma@postgres:5432/sevenma

# 如果切到远程数据库：
# 1. 把 COMPOSE_PROFILES 置空或删除
# 2. 把 DATABASE_URL 改成远程连接串

POSTGRES_DB=sevenma
POSTGRES_USER=sevenma
POSTGRES_PASSWORD=sevenma
POSTGRES_PORT=5432

SEVENMA_SOURCE_NAMESPACE=prod
SEVENMA_COLLECTOR_ID=collector-compose
SEVENMA_INTERVAL_SECONDS=60
SEVENMA_CONCURRENCY=8
SEVENMA_TIMEOUT_SECONDS=10
SEVENMA_REQUEST_JITTER_SECONDS=0.35

SEVENMA_DASHBOARD_SOURCE_NAMESPACE=prod
SEVENMA_DASHBOARD_HOST=0.0.0.0
SEVENMA_DASHBOARD_PORT=8000
SEVENMA_DASHBOARD_REFRESH_SECONDS=20
SEVENMA_DASHBOARD_VEHICLE_LIMIT=1500
DASHBOARD_PORT=8000

AMAP_WEB_KEY=
AMAP_SECURITY_JS_CODE=
